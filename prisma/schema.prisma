generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  userId       String    @id @default(cuid()) @map("user_id")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  email        String    @unique
  phone        String
  username     String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("customer") // admin, owner, customer
  isVerified   Boolean   @default(false) @map("is_verified")
  createdAt    DateTime  @default(now()) @map("created_at")

  otpVerifications  OtpVerification[]
  ownedHalls        WeddingHall[]
  bookings          Booking[]
  reviews           Review[]
  favorites         Favorite[]

  @@map("users")
}

model OtpVerification {
  otpId     String   @id @default(cuid()) @map("otp_id")
  userId    String   @map("user_id")
  otpCode   String   @map("otp_code")
  expiryTime DateTime @map("expiry_time")
  isUsed    Boolean  @default(false) @map("is_used")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("otp_verifications")
}

model WeddingHall {
  hallId           String   @id @default(cuid()) @map("hall_id")
  ownerId          String   @map("owner_id")
  name             String
  district         String
  address          String
  capacity         Int
  seatPrice        Float    @map("seat_price")
  phone            String
  hasKarnaySurnay  Boolean  @default(false) @map("has_karnay_surnay")
  karnaySurnayPrice Float?  @map("karnay_surnay_price")
  status           String   @default("pending") // approved, pending
  createdAt        DateTime @default(now()) @map("created_at")

  owner    User         @relation(fields: [ownerId], references: [userId], onDelete: Cascade)
  images   HallImage[]
  singers  Singer[]
  menus    Menu[]
  cars     Car[]
  bookings Booking[]
  reviews  Review[]
  favorites Favorite[]

  @@map("wedding_halls")
}

model HallImage {
  imageId  String @id @default(cuid()) @map("image_id")
  hallId   String @map("hall_id")
  imageUrl String @map("image_url")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)

  @@map("hall_images")
}

model Singer {
  singerId   String @id @default(cuid()) @map("singer_id")
  hallId     String @map("hall_id")
  singerName String @map("singer_name")
  price      Float
  imageUrl   String? @map("image_url")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)

  @@map("singers")
}

model Menu {
  menuId   String @id @default(cuid()) @map("menu_id")
  hallId   String @map("hall_id")
  menuName String @map("menu_name")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)

  @@map("menus")
}

model Car {
  carId    String @id @default(cuid()) @map("car_id")
  hallId   String @map("hall_id")
  brand    String
  price    Float
  imageUrl String? @map("image_url")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)

  @@map("cars")
}

model Booking {
  bookingId      String   @id @default(cuid()) @map("booking_id")
  hallId         String   @map("hall_id")
  customerId     String   @map("customer_id")
  bookingDate    String   @map("booking_date")
  guestCount     Int      @map("guest_count")
  totalPrice     Float    @map("total_price")
  advancePayment Float    @map("advance_payment")
  bookingStatus  String   @default("upcoming") // upcoming, completed, cancelled
  createdAt      DateTime @default(now()) @map("created_at")

  hall      WeddingHall     @relation(fields: [hallId], references: [hallId], onDelete: Cascade)
  customer  User            @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  services  BookingService[]

  @@map("bookings")
}

model BookingService {
  bookingServiceId String @id @default(cuid()) @map("booking_service_id")
  bookingId        String @map("booking_id")
  serviceType      String @map("service_type") // singer, menu, car, karnay_surnay
  serviceId        String @map("service_id")
  servicePrice     Float  @map("service_price")

  booking Booking @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)

  @@map("booking_services")
}

model Review {
  reviewId  String   @id @default(cuid()) @map("review_id")
  hallId    String   @map("hall_id")
  userId    String   @map("user_id")
  rating    Int      // 1-5 stars
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([hallId, userId]) // One review per user per hall
  @@map("reviews")
}

model Favorite {
  favoriteId String @id @default(cuid()) @map("favorite_id")
  hallId     String @map("hall_id")
  userId     String @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([hallId, userId]) // One favorite per user per hall
  @@map("favorites")
}
