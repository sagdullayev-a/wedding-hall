generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId       String    @id @default(cuid()) @map("user_id")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  email        String    @unique
  phone        String
  username     String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("customer")
  avatarUrl    String?   @map("avatar_url")
  isVerified   Boolean   @default(false) @map("is_verified")
  createdAt    DateTime  @default(now()) @map("created_at")

  otpVerifications  OtpVerification[]
  ownedHalls        WeddingHall[]
  bookings          Booking[]
  reviews           Review[]
  favorites         Favorite[]
  notifications     Notification[]

  @@map("users")
}

model OtpVerification {
  otpId        String   @id @default(cuid()) @map("otp_id")
  userId       String   @map("user_id")
  otpCode      String   @map("otp_code")
  expiryTime   DateTime @map("expiry_time")
  isUsed       Boolean  @default(false) @map("is_used")
  attemptCount Int      @default(0) @map("attempt_count")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("otp_verifications")
}

model WeddingHall {
  hallId            String     @id @default(cuid()) @map("hall_id")
  ownerId           String     @map("owner_id")
  name              String
  district          String
  address           String
  capacity          Int
  seatPrice         Float      @map("seat_price")
  phone             String
  hasKarnaySurnay   Boolean    @default(false) @map("has_karnay_surnay")
  karnaySurnayPrice Float?     @map("karnay_surnay_price")
  status            String     @default("pending")
  createdAt         DateTime   @default(now()) @map("created_at")

  owner     User       @relation(fields: [ownerId], references: [userId], onDelete: Cascade)
  images    HallImage[]
  singers   Singer[]
  menus     Menu[]
  cars      Car[]
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]

  @@index([ownerId])
  @@index([district])
  @@map("wedding_halls")
}

model HallImage {
  imageId  String @id @default(cuid()) @map("image_id")
  hallId   String @map("hall_id")
  imageUrl String @map("image_url")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)

  @@index([hallId])
  @@map("hall_images")
}

model Singer {
  singerId   String @id @default(cuid()) @map("singer_id")
  hallId     String @map("hall_id")
  singerName String @map("singer_name")
  price      Float
  imageUrl   String? @map("image_url")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)

  @@index([hallId])
  @@map("singers")
}

model Menu {
  menuId   String @id @default(cuid()) @map("menu_id")
  hallId   String @map("hall_id")
  menuName String @map("menu_name")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)

  @@index([hallId])
  @@map("menus")
}

model Car {
  carId    String @id @default(cuid()) @map("car_id")
  hallId   String @map("hall_id")
  brand    String
  price    Float
  imageUrl String? @map("image_url")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)

  @@index([hallId])
  @@map("cars")
}

model Booking {
  bookingId      String        @id @default(cuid()) @map("booking_id")
  hallId         String        @map("hall_id")
  customerId     String        @map("customer_id")
  bookingDate    String        @map("booking_date")
  guestCount     Int           @map("guest_count")
  totalPrice     Float         @map("total_price")
  advancePayment Float         @map("advance_payment")
  bookingStatus  String        @default("upcoming")
  createdAt      DateTime      @default(now()) @map("created_at")

  hall     WeddingHall      @relation(fields: [hallId], references: [hallId], onDelete: Cascade)
  customer User             @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  services BookingService[]

  @@index([hallId])
  @@index([customerId])
  @@index([bookingDate])
  @@map("bookings")
}

model BookingService {
  bookingServiceId String      @id @default(cuid()) @map("booking_service_id")
  bookingId        String      @map("booking_id")
  serviceType      String      @map("service_type")
  serviceId        String      @map("service_id")
  servicePrice     Float       @map("service_price")

  booking Booking @relation(fields: [bookingId], references: [bookingId], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_services")
}

model Review {
  reviewId      String    @id @default(cuid()) @map("review_id")
  hallId        String    @map("hall_id")
  userId        String    @map("user_id")
  rating        Int
  comment       String?
  ownerResponse String?   @map("owner_response")
  respondedAt   DateTime? @map("responded_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([hallId, userId])
  @@index([userId])
  @@map("reviews")
}

model Favorite {
  favoriteId String   @id @default(cuid()) @map("favorite_id")
  hallId     String   @map("hall_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  hall WeddingHall @relation(fields: [hallId], references: [hallId], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([hallId, userId])
  @@index([userId])
  @@map("favorites")
}

model Notification {
  notificationId String           @id @default(cuid()) @map("notification_id")
  userId         String           @map("user_id")
  title          String
  message        String
  type           String           @default("info")
  isRead         Boolean          @default(false) @map("is_read")
  createdAt      DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
